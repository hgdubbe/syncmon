#!/bin/bash

################################################################################
#                  SQL SYNC WATCH - TEST CONNECTIVITY                          #
#        Verifies all database and service connectivity before run             #
################################################################################

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CONFIG_FILE="${SCRIPT_DIR}/sync_monitor.conf"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
BOLD='\033[1m'
RESET='\033[0m'

echo -e "${BOLD}${CYAN}"
echo "╔════════════════════════════════════════════════════════════╗"
echo "║   SQL SYNC WATCH - Connectivity Test                       ║"
echo "║   Testing all configured services                          ║"
echo "╚════════════════════════════════════════════════════════════╝"
echo -e "${RESET}"
echo ""

# Load config
if [[ ! -f "$CONFIG_FILE" ]]; then
    echo -e "${RED}✗ Configuration file not found: $CONFIG_FILE${RESET}"
    exit 1
fi

source "$CONFIG_FILE"

PASSED=0
FAILED=0

test_result() {
    local name=$1
    local result=$2
    local message=$3

    if [[ $result -eq 0 ]]; then
        echo -e "${GREEN}✓${RESET} $name"
        if [[ -n "$message" ]]; then
            echo -e "  ${CYAN}→${RESET} $message"
        fi
        PASSED=$((PASSED + 1))
    else
        echo -e "${RED}✗${RESET} $name"
        if [[ -n "$message" ]]; then
            echo -e "  ${YELLOW}→${RESET} $message"
        fi
        FAILED=$((FAILED + 1))
    fi
}

# Test 1: Config file
echo -e "${BOLD}Configuration${RESET}"
test_result "Config file readable" 0 "$CONFIG_FILE"

# Test 2: MySQL master
echo ""
echo -e "${BOLD}MySQL (dbmaster - Master)${RESET}"
MYSQL_CMD="mysql -h $MYSQL_MASTER_HOST -P $MYSQL_MASTER_PORT -u $MYSQL_USER ${MYSQL_PASSWORD:+-p $MYSQL_PASSWORD} -e \"SELECT 1;\" 2>&1"
if eval "$MYSQL_CMD" >/dev/null 2>&1; then
    test_result "MySQL master connection" 0 "Successfully connected to $MYSQL_MASTER_HOST:$MYSQL_MASTER_PORT"
else
    test_result "MySQL master connection" 1 "Failed to connect to $MYSQL_MASTER_HOST:$MYSQL_MASTER_PORT as $MYSQL_USER"
    echo -e "  ${YELLOW}Command:${RESET} $MYSQL_CMD"
fi

if MASTER_GTID=$(mysql -h "$MYSQL_MASTER_HOST" -P "$MYSQL_MASTER_PORT" -u "$MYSQL_USER" ${MYSQL_PASSWORD:+-p"$MYSQL_PASSWORD"} -N -B -e "select @@global.gtid_binlog_pos;"); then   # | grep -q "gtid_binlog_pos"; then
    test_result "Master GTID retrieval" 0 "Master GTID: $MASTER_GTID"
else
    test_result "Master GTID retrieval" 1 "Could not read gtid_binlog_pos variable"
fi

# Test 3: MySQL slave
echo ""
echo -e "${BOLD}MySQL (dbslave - Slave)${RESET}"
if mysql -h $MYSQL_SLAVE_HOST -P $MYSQL_SLAVE_PORT -u $MYSQL_USER ${MYSQL_PASSWORD:+-p$MYSQL_PASSWORD} -e "SELECT 1;" >/dev/null 2>&1; then
    test_result "MySQL slave connection" 0 "Connected to $MYSQL_SLAVE_HOST:$MYSQL_SLAVE_PORT (direct)"

    SLAVE_GTID=$(mysql -h "$MYSQL_SLAVE_HOST" -P "$MYSQL_SLAVE_PORT" -u "$MYSQL_USER" ${MYSQL_PASSWORD:+-p"$MYSQL_PASSWORD"} -N -B -e "select @@global.gtid_slave_pos;")
    if [[ -n "$SLAVE_GTID" ]]; then
        test_result "Slave GTID retrieval" 0 "Slave GTID: $SLAVE_GTID"

        if [[ "$MASTER_GTID" == "$SLAVE_GTID" ]]; then
            test_result "GTID synchronization" 0 "Master and slave GTIDs match ($GTID_VALUE)"
        else
            test_result "GTID synchronization" 1 "GTIDs do not match: Master=$GTID_VALUE, Slave=$SLAVE_GTID"
        fi
    else
        test_result "Slave GTID retrieval" 1 "Could not read slave GTID"
    fi
else
    test_result "MySQL slave connection" 1 "Failed to connect to $MYSQL_SLAVE_HOST:$MYSQL_SLAVE_PORT"
fi

# Test 4: Redis slave
if [[ $ENABLE_REDIS_CHECK -eq 1 ]]; then
    echo ""
    echo -e "${BOLD}Redis replication${RESET}"

    if redis-cli --no-auth-warning -h "$REDIS_MASTER_HOST" -p "$REDIS_MASTER_PORT" -a "$REDIS_PASSWORD" ping >/dev/null 2>&1; then
        test_result "Redis master connection" 0 "Connected to $REDIS_MASTER_HOST:$REDIS_MASTER_PORT"
    else
        test_result "Redis master connection" 1 "Failed to connect to $REDIS_MASTER_HOST:$REDIS_MASTER_PORT"
    fi

    if redis-cli --no-auth-warning -h "$REDIS_SLAVE_HOST" -p "$REDIS_SLAVE_PORT" -a "$REDIS_PASSWORD" ping >/dev/null 2>&1; then
        test_result "Redis replica connection" 0 "Connected to $REDIS_SLAVE_HOST:$REDIS_SLAVE_PORT"
    else
        test_result "Redis replica connection" 1 "Failed to connect to $REDIS_SLAVE_HOST:$REDIS_SLAVE_PORT"
    fi

    MASTER_TEST_KEY="REPL_TEST_$(date +%s)"
    MASTER_TEST_VAL="data_$(date +%N)"

    if redis-cli --no-auth-warning -h "$REDIS_MASTER_HOST" -p "$REDIS_MASTER_PORT" -a "$REDIS_PASSWORD" SET "$MASTER_TEST_KEY" "$MASTER_TEST_VAL" EX 300 >/dev/null 2>&1; then
        sleep 1
        SLAVE_VALUE=$(redis-cli --no-auth-warning -h "$REDIS_SLAVE_HOST" -p "$REDIS_SLAVE_PORT" -a "$REDIS_PASSWORD" --raw GET "$MASTER_TEST_KEY" 2>/dev/null)

        if [[ "$SLAVE_VALUE" == "$MASTER_TEST_VAL" ]]; then
            test_result "Redis replication" 0 "Master-replica replication working"
        else
            test_result "Redis replication" 1 "Replication lag or mismatch detected"
            echo -e "  ${YELLOW}Expected:${RESET} $MASTER_TEST_VAL"
            echo -e "  ${YELLOW}Got:${RESET} $SLAVE_VALUE"
        fi
    else
        test_result "Redis replication" 1 "Failed to write test key on master"
    fi
fi
# Summary
echo ""
echo "════════════════════════════════════════════════════════════"
echo -e "${BOLD}Test Summary${RESET}"
echo -e "${GREEN}Passed: $PASSED${RESET} | ${RED}Failed: $FAILED${RESET}"
echo ""

if [[ $FAILED -eq 0 ]]; then
    echo -e "${GREEN}✓ All tests passed! Ready to run sync_monitor.sh${RESET}"
    exit 0
else
    echo -e "${RED}✗ Some tests failed. Please review the errors above.${RESET}"
    exit 1
fi